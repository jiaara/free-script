<style>
  /* ===== SLIDER OTOMATIS ===== */
  .slider-container {
    width: 100%;
    overflow: hidden;
    position: relative;
  }

  .slider-track {
    display: flex;
    gap: 20px;
    width: max-content;
    /* Animasi berjalan terus tanpa henti */
    animation: scroll 20s linear infinite;
  }

  .slide-card {
    width: 320px;
    height: 240px;
    flex-shrink: 0;
    border-radius: 16px;
    overflow: hidden;
    background-color: #eee;
  }

  .slide-card img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  /* Kunci looping mulus: Geser persis setengah dari total lebar track + setengah gap (10px) */
  @keyframes scroll {
    0% { transform: translateX(0); }
    100% { transform: translateX(calc(-50% - 10px)); } 
  }

  /* === RESPONSIVE === */
  @media (max-width: 768px) {
    .slide-card {
      width: 260px;
      height: 200px;
    }
  }
</style>

